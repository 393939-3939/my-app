<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TODO Tree</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-50 px-6 py-10 text-slate-800">
  <div class="mx-auto max-w-5xl rounded-3xl border border-slate-200 bg-white p-8 shadow-xl">
    <div class="mb-6 flex items-center justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-slate-500">Task Tree</p>
        <h1 class="text-2xl font-black">タスク関係のツリー</h1>
      </div>
      <a href="/" class="rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">戻る</a>
    </div>

    <div class="space-y-2">
      <% function renderNode(node, depth = 0) { %>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-2.5" style="margin-left: <%= depth * 18 %>px;">
          <div class="flex items-center gap-2">
            <span class="text-xs font-semibold text-slate-500"><%= ' '.repeat(depth * 2) %>├─</span>
            <div>
              <div class="text-sm font-semibold"><%= node.content %></div>
              <div class="text-[11px] text-slate-500">親として選ばれた数: <%= node.parentCount || 0 %></div>
            </div>
          </div>
        </div>
        <% if (node.children && node.children.length) { %>
          <% node.children.forEach((child) => renderNode(child, depth + 1)); %>
        <% } %>
      <% } %>

      <% tasks.forEach((task) => renderNode(task)); %>
    </div>
  </div>
</body>
</html>
