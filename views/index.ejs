<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TODO Board</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen px-4 py-10 transition-colors duration-300 <%= theme === 'rose' ? 'bg-rose-50 text-rose-950' : theme === 'violet' ? 'bg-violet-50 text-violet-950' : 'bg-sky-50 text-sky-950' %>">
  <div class="mx-auto max-w-6xl space-y-8">
    <header class="rounded-3xl border border-white/70 bg-white/70 p-6 shadow-xl backdrop-blur">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-slate-500">Task Focus</p>
          <h1 class="text-3xl font-black">今日のTODO</h1>
          <p class="mt-2 text-sm text-slate-600">進捗・期限・説明・関係性を一目で管理できるボードです。</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <form action="/theme" method="post" class="flex items-center gap-2">
            <label class="text-sm font-medium text-slate-600" for="theme">テーマ</label>
            <select id="theme" name="theme" class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
              <option value="sky" <%= theme === 'sky' ? 'selected' : '' %>>スカイ</option>
              <option value="rose" <%= theme === 'rose' ? 'selected' : '' %>>ローズ</option>
              <option value="violet" <%= theme === 'violet' ? 'selected' : '' %>>バイオレット</option>
            </select>
            <button class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white">保存</button>
          </form>
        </div>
      </div>
    </header>

    <section class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-3xl border border-white/80 bg-white/80 p-6 shadow-xl backdrop-blur">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-xl font-bold">タスク一覧</h2>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-600"><%= tasks.length %>件</span>
        </div>
        <div class="space-y-2">
          <% 
            // 循環参照を防ぐヘルパー関数（自分自身または子孫タスクか判定）
            function isDescendantOrSelf(currentTask, targetId) {
              if (currentTask.id === targetId) return true;
              if (currentTask.children && currentTask.children.length) {
                return currentTask.children.some(child => isDescendantOrSelf(child, targetId));
              }
              return false;
            }

            // datetime-local 用のローカルタイム文字列生成ヘルパー
            function toLocalIsoString(date) {
              if (!date) return '';
              const offset = date.getTimezoneOffset() * 60000;
              const localDate = new Date(date.getTime() - offset);
              return localDate.toISOString().slice(0, 16);
            }

            // 再帰的にタスクをレンダリングする関数
            function renderTask(task, depth = 0) { 
          %>
            <article class="rounded-xl border border-slate-200 bg-white p-3 shadow-sm" style="margin-left: <%= depth * 32 %>px;">
              <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full px-2.5 py-1 text-xs font-semibold <%= task.priority === 'high' ? 'bg-red-100 text-red-700' : task.priority === 'low' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                      <%= task.priority === 'high' ? '高' : task.priority === 'low' ? '低' : '中' %>
                    </span>

                    <% if (task.parent && task.parent.content) { %>
                      <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs text-slate-600">親: <%= task.parent.content %></span>
                    <% } %>

                    <% if (task.isUrgent) { %>
                      <span class="rounded-full bg-red-600 px-2.5 py-1 text-xs font-semibold text-white">期限間近</span>
                    <% } %>
                  </div>

                  <h3 class="mt-2 text-base font-semibold text-slate-800"><%= task.content %></h3>

                  <% if (task.renderedDetails) { %>
                    <div class="mt-2 max-w-none text-xs leading-5 text-slate-600"><%- task.renderedDetails %></div>
                  <% } %>

                  <div class="mt-2 space-y-2 text-xs text-slate-600">
                    <div>
                      <div class="mb-1 flex items-center justify-between">
                        <span>進捗</span>
                        <span><%= task.progress %>%</span>
                      </div>
                      <div class="h-2 rounded-full bg-slate-200">
                        <div class="h-2 rounded-full bg-gradient-to-r from-sky-500 to-emerald-500" style="width: <%= task.progress %>%"></div>
                      </div>
                    </div>
                    <div class="flex flex-wrap gap-4">
                      <span>作成: <%= task.createdAt.toLocaleString('ja-JP') %></span>
                      <% if (task.dueDate) { %>
                        <span>期限: <%= task.dueDate.toLocaleString('ja-JP') %></span>
                      <% } %>
                      <% if (task.dueDateIso) { %>
                        <span>残り: <span class="task-remaining-text" data-remaining-target data-due-date="<%= task.dueDateIso %>"><%= task.remainingText || '' %></span></span>
                      <% } %>
                    </div>
                  </div>
                </div>
                <div class="flex flex-col gap-2 lg:min-w-[190px]">
                  <button type="button" class="rounded-full bg-slate-900 px-3 py-2 text-xs font-semibold text-white" onclick="document.getElementById('edit-<%= task.id %>').classList.toggle('hidden')">編集</button>
                  <form action="/tasks/parent" method="post" class="flex items-center gap-2">
                    <input type="hidden" name="id" value="<%= task.id %>" />
                    <select name="parentId" class="w-full rounded-lg border border-slate-300 px-2 py-1.5 text-xs">
                      <option value="">親タスクなし</option>
                      <% tasks.forEach(parentTask => { %>
                        <% if (!isDescendantOrSelf(task, parentTask.id)) { %>
                          <option value="<%= parentTask.id %>" <%= task.parentId === parentTask.id ? 'selected' : '' %>><%= parentTask.content %></option>
                        <% } %>
                      <% }) %>
                    </select>
                    <button type="submit" class="rounded-full bg-slate-700 px-2.5 py-1.5 text-[11px] font-semibold text-white">親変更</button>
                  </form>
                  <form action="/tasks/delete" method="post" class="delete-form">
                    <input type="hidden" name="id" value="<%= task.id %>" />
                    <button type="submit" class="w-full rounded-full bg-red-500 px-3 py-2 text-xs font-semibold text-white delete-button">削除</button>
                  </form>
                </div>
              </div>
              <form id="edit-<%= task.id %>" action="/tasks/update" method="post" class="mt-3 hidden rounded-2xl border border-slate-200 bg-slate-50 p-3">
                <input type="hidden" name="id" value="<%= task.id %>" />
                <div class="grid gap-2 md:grid-cols-2">
                  <input type="text" name="content" value="<%= task.content %>" class="rounded-lg border border-slate-300 px-2.5 py-2 text-sm" required>
                  <div class="md:col-span-2">
                    <label class="mb-1 block text-xs font-medium text-slate-600">進捗</label>
                    <input type="range" name="progress" min="0" max="100" step="10" value="<%= task.progress %>" class="w-full progress-slider" data-progress-display="progress-display-<%= task.id %>">
                    <div class="mt-1 text-xs text-slate-500">現在: <span id="progress-display-<%= task.id %>"><%= task.progress %></span>%</div>
                  </div>
                  <textarea name="details" rows="3" class="md:col-span-2 rounded-lg border border-slate-300 px-2.5 py-2 text-sm" placeholder="詳細・メモ（Markdown可）"><%= task.details || '' %></textarea>
                  <div>
                    <label class="mb-1 block text-xs font-medium text-slate-600">優先度</label>
                    <select name="priority" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
                      <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>>高</option>
                      <option value="normal" <%= task.priority === 'normal' ? 'selected' : '' %>>中</option>
                      <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>>低</option>
                    </select>
                  </div>
                  <input type="datetime-local" name="dueDate" value="<%= toLocalIsoString(task.dueDate) %>" class="rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
                </div>
                <div class="mt-3 flex justify-end">
                  <button type="submit" class="rounded-full bg-sky-600 px-3 py-2 text-xs font-semibold text-white">更新</button>
                </div>
              </form>
            </article>
            <% 
              // 子タスクが存在すれば、再帰呼び出しして出力バッファに書き込む
              if (task.children && task.children.length) { 
                task.children.forEach(child => { 
                  renderTask(child, depth + 1); 
                }); 
              } 
            } // renderTask 関数の閉じ
            %>

          <% rootTasks.forEach(task => { %>
            <% renderTask(task); %>
          <% }); %>
        </div>
      </div>

      <aside class="rounded-3xl border border-white/80 bg-white/80 p-6 shadow-xl backdrop-blur">
          <h2 class="text-xl font-bold">ユーザーIDでログイン</h2>

          <% if (!currentUserId) { %>
            <p class="mb-3 text-sm text-slate-600">初回は新規登録、2回目以降はログインでタスクを切り替えます。</p>
            <% if (loginError) { %>
              <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= loginError %></div>
            <% } %>
            <form action="/session" method="post" class="space-y-3">
              <input type="text" name="userId" value="<%= prefillUserId %>" placeholder="ユーザーID（半角英数字のみ）" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
              <div class="flex gap-2">
                <button type="submit" name="action" value="login" class="w-1/2 rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white">ログイン</button>
                <button type="submit" name="action" value="register" class="w-1/2 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700">新規登録</button>
              </div>
            </form>
          <% } else { %>
            <p class="mb-3 text-sm text-slate-600">現在のログイン: <span class="font-medium"><%= currentUserId %></span></p>
            <form action="/logout" method="post" class="mb-6">
              <button type="submit" class="w-full rounded-full bg-red-600 px-4 py-2 text-sm font-semibold text-white">ログアウト</button>
            </form>
            <h3 class="text-lg font-semibold">新しいタスク</h3>
            <form action="/tasks" method="post" class="mt-4 space-y-2.5">
              <input type="text" name="content" placeholder="タスク名" required class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
              <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">進捗</label>
                <input type="range" name="progress" min="0" max="100" step="10" value="0" class="w-full progress-slider" data-progress-display="new-progress-display">
                <div class="mt-1 text-xs text-slate-500">現在: <span id="new-progress-display">0</span>%</div>
              </div>
              <textarea name="details" rows="4" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm" placeholder="詳細・メモ（Markdown可）"></textarea>
              <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">優先度</label>
                <select name="priority" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
                  <option value="high">高</option>
                  <option value="normal" selected>中</option>
                  <option value="low">低</option>
                </select>
              </div>
              <input type="datetime-local" name="dueDate" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
              <button type="submit" class="w-full rounded-full bg-sky-600 px-3 py-2 text-sm font-semibold text-white">追加</button>
            </form>
          <% } %>
        </aside>
    </section>
  </div>

  <script>
    function formatRemainingText(remainingSeconds) {
      if (remainingSeconds <= 0) {
        return '期限切れ';
      }

      const days = Math.floor(remainingSeconds / 86400);
      const hours = Math.floor((remainingSeconds % 86400) / 3600);
      const minutes = Math.floor((remainingSeconds % 3600) / 60);
      const seconds = remainingSeconds % 60;

      return `${days}日 ${hours}時間 ${minutes}分 ${seconds}秒`;
    }

    function updateRemainingTimes() {
      const now = Date.now();

      document.querySelectorAll('[data-remaining-target]').forEach((element) => {
        const dueDateValue = element.dataset.dueDate;
        if (!dueDateValue) {
          element.textContent = '';
          return;
        }

        const targetTime = new Date(dueDateValue).getTime();
        const remainingSeconds = Math.max(0, Math.floor((targetTime - now) / 1000));
        const isUrgent = remainingSeconds > 0 && remainingSeconds <= 21600;
        const article = element.closest('article');

        if (article) {
          article.classList.toggle('border-red-400', isUrgent);
          article.classList.toggle('bg-red-50', isUrgent);
          article.classList.toggle('ring-2', isUrgent);
          article.classList.toggle('ring-red-300', isUrgent);
        }

        element.textContent = formatRemainingText(remainingSeconds);
      });
    }

    updateRemainingTimes();
    setInterval(updateRemainingTimes, 1000);

    document.querySelectorAll('.progress-slider').forEach((slider) => {
      const target = document.getElementById(slider.dataset.progressDisplay);
      if (target) {
        target.textContent = slider.value;
      }
      slider.addEventListener('input', () => {
        const target = document.getElementById(slider.dataset.progressDisplay);
        if (target) {
          target.textContent = slider.value;
        }
      });
    });

    document.querySelectorAll('.delete-button').forEach((button) => {
      button.addEventListener('click', (event) => {
        if (!button.dataset.confirmed) {
          event.preventDefault();
          button.dataset.confirmed = 'true';
          button.textContent = '本当に削除';
          button.classList.remove('bg-red-500');
          button.classList.add('bg-red-700');
          setTimeout(() => {
            button.dataset.confirmed = '';
            button.textContent = '削除';
            button.classList.remove('bg-red-700');
            button.classList.add('bg-red-500');
          }, 2000);
        }
      });
    });
  </script>
</body>
</html>