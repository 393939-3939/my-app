<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TASK SEIRI</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen px-4 py-10 transition-colors duration-300 <%= theme === 'rose' ? 'bg-rose-50 text-rose-950' : theme === 'violet' ? 'bg-violet-50 text-violet-950' : 'bg-sky-50 text-sky-950' %>">
  <div class="mx-auto max-w-6xl space-y-8">
    <header class="rounded-3xl border border-white/70 bg-white/70 p-6 shadow-xl backdrop-blur">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-slate-500">Task Seiri</p>
          <h1 class="text-3xl font-black">タスク整理</h1>
        </div>
        <div class="flex flex-wrap items-center gap-4">
          <form action="/theme" method="post" class="flex items-center gap-2">
            <label class="text-sm font-medium text-slate-600" for="theme">テーマ</label>
            <select id="theme" name="theme" class="rounded-full border border-slate-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
              <option value="sky" <%= theme === 'sky' ? 'selected' : '' %>>スカイ</option>
              <option value="rose" <%= theme === 'rose' ? 'selected' : '' %>>ローズ</option>
              <option value="violet" <%= theme === 'violet' ? 'selected' : '' %>>バイオレット</option>
            </select>
            <button class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white">決定</button>
          </form>

          <% if (currentUserId) { %>
            <div class="flex items-center gap-3 border-l border-slate-300 pl-4">
              <span class="text-xs text-slate-600">ユーザー: <span class="font-bold"><%= currentUserId %></span></span>
              <form action="/logout" method="post">
                <button type="submit" class="rounded-full bg-red-500 hover:bg-red-600 px-3 py-1.5 text-xs font-semibold text-white transition-colors">ログアウト</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </header>

    <section class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-3xl border border-white/80 bg-white/80 p-6 shadow-xl backdrop-blur">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-xl font-bold">タスク一覧</h2>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-600"><%= tasks.length %>件</span>
        </div>
        <div class="space-y-2">
          <% 
            function isDescendantOrSelf(currentTask, targetId) {
              if (currentTask.id === targetId) return true;
              if (currentTask.children && currentTask.children.length) {
                return currentTask.children.some(child => isDescendantOrSelf(child, targetId));
              }
              return false;
            }

            function toLocalIsoString(date) {
              if (!date) return '';
              const offset = date.getTimezoneOffset() * 60000;
              const localDate = new Date(date.getTime() - offset);
              return localDate.toISOString().slice(0, 16);
            }

            function renderTask(task, depth = 0) { 
              const lightness = Math.max(0, 90 - (depth * 7));
              const backgroundColor = `hsl(215, 10%, ${lightness}%)`;
              const paddingLeft = depth * 24;
          %>
            <div style="padding-left: <%= paddingLeft %>px;" class="w-full">
              <article data-task-card="<%= task.id %>" class="cursor-pointer rounded-xl border border-slate-200 p-4 shadow-sm transition-all duration-200 hover:shadow-md" 
                       style="background-color: <%= backgroundColor %>;">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="rounded-full px-2.5 py-1 text-xs font-semibold <%= task.priority === 'high' ? 'bg-red-100 text-red-700' : task.priority === 'low' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                        <%= task.priority === 'high' ? '優先度：高' : task.priority === 'low' ? '優先度：低' : '優先度：中' %>
                      </span>

                      <% if (task.parent && task.parent.content) { %>
                        <span class="rounded-full bg-white px-2.5 py-1 text-xs text-slate-600 border border-slate-200 shadow-sm">元タスク: <%= task.parent.content %></span>
                      <% } %>

                      <% if (task.isUrgent) { %>
                        <span class="rounded-full bg-amber-500 px-2.5 py-1 text-xs font-semibold text-white">期限間近</span>
                      <% } %>
                    </div>

                    <h3 class="mt-2 text-base font-semibold text-slate-800"><%= task.content %></h3>

                    <% if (task.renderedDetails) { %>
                      <div class="mt-2 max-w-none text-xs leading-5 text-slate-600"><%- task.renderedDetails %></div>
                    <% } %>

                    <div class="mt-2 space-y-2 text-xs text-slate-600">
                      <div>
                        <div class="mb-1 flex items-center justify-between">
                          <span>進捗</span>
                          <span><%= task.progress %>%</span>
                        </div>
                        <div class="h-2 rounded-full bg-slate-200/60">
                          <div class="h-2 rounded-full bg-gradient-to-r from-sky-500 to-emerald-500" style="width: <%= task.progress %>%"></div>
                        </div>
                      </div>
                      <div class="flex flex-wrap gap-4">
                        <span>作成: <%= task.createdAt.toLocaleString('ja-JP') %></span>
                        <% if (task.dueDate) { %>
                          <span>期限: <%= task.dueDate.toLocaleString('ja-JP') %></span>
                        <% } %>
                        <% if (task.dueDateIso) { %>
                          <span>残り: <span class="task-remaining-text" data-remaining-target data-due-date="<%= task.dueDateIso %>"><%= task.remainingText || '' %></span></span>
                        <% } %>
                      </div>
                    </div>
                  </div>

                  <div class="flex flex-col gap-2 lg:min-w-[220px] w-full lg:w-auto">
                    <button type="button" class="w-full rounded-xl bg-slate-900 hover:bg-slate-800 px-4 py-2.5 text-sm font-semibold text-white transition-colors shadow-sm" onclick="document.getElementById('edit-<%= task.id %>').classList.toggle('hidden')">
                      編集する
                    </button>
                    
                    <form action="/tasks/parent" method="post" class="flex flex-col gap-1.5 w-full border-t border-slate-300/50 pt-2 lg:border-t-0 lg:pt-0">
                      <input type="hidden" name="id" value="<%= task.id %>" />
                      <select name="parentId" class="w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
                        <option value="">元タスクなし</option>
                        <% tasks.forEach(parentTask => { %>
                          <% if (!isDescendantOrSelf(task, parentTask.id)) { %>
                            <option value="<%= parentTask.id %>" <%= task.parentId === parentTask.id ? 'selected' : '' %>><%= parentTask.content %></option>
                          <% } %>
                        <% }) %>
                      </select>
                      <button type="submit" class="w-full rounded-xl bg-slate-700 hover:bg-slate-600 px-3 py-2 text-xs font-semibold text-white transition-colors shadow-sm">
                        元タスクを変更
                      </button>
                    </form>

                    <form id="delete-form-<%= task.id %>" action="/tasks/delete" method="post" class="hidden">
                      <input type="hidden" name="id" value="<%= task.id %>" />
                    </form>
                  </div>
                </div>

                <form id="edit-<%= task.id %>" action="/tasks/update" method="post" class="mt-3 hidden rounded-2xl border border-slate-200 bg-white p-3 shadow-inner">
                  <input type="hidden" name="id" value="<%= task.id %>" />
                  <div class="grid gap-2 md:grid-cols-2">
                    <input type="text" name="content" value="<%= task.content %>" class="rounded-lg border border-slate-300 px-2.5 py-2 text-sm" required>
                    <div class="md:col-span-2">
                      <label class="mb-1 block text-xs font-medium text-slate-600">進捗</label>
                      <input type="range" name="progress" min="0" max="100" step="10" value="<%= task.progress %>" class="w-full progress-slider" data-progress-display="progress-display-<%= task.id %>">
                      <div class="mt-1 text-xs text-slate-500">現在: <span id="progress-display-<%= task.id %>"><%= task.progress %></span>%</div>
                    </div>
                    <textarea name="details" rows="3" class="md:col-span-2 rounded-lg border border-slate-300 px-2.5 py-2 text-sm" placeholder="詳細"><%= task.details || '' %></textarea>
                    <div>
                      <label class="mb-1 block text-xs font-medium text-slate-600">優先度</label>
                      <select name="priority" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
                        <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>>優先度：高</option>
                        <option value="normal" <%= task.priority === 'normal' ? 'selected' : '' %>>優先度：中</option>
                        <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>>優先度：低</option>
                      </select>
                    </div>
                    <input type="datetime-local" name="dueDate" value="<%= toLocalIsoString(task.dueDate) %>" class="rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
                  </div>
                  <div class="mt-3 flex justify-end">
                    <button type="submit" class="rounded-full bg-sky-600 px-3 py-2 text-xs font-semibold text-white">更新</button>
                  </div>
                </form>
              </article>
            </div>
          <% 
              if (task.children && task.children.length) { 
                task.children.forEach(child => { 
                  renderTask(child, depth + 1); 
                }); 
              } 
            } 
          %>

          <% rootTasks.forEach(task => { %>
            <% renderTask(task); %>
          <% }); %>
        </div>
      </div>

      <aside class="rounded-3xl border border-white/80 bg-white/80 p-6 shadow-xl backdrop-blur">
          <% if (!currentUserId) { %>
            <h2 class="text-xl font-bold">ユーザーIDでログイン</h2>
            <p class="mb-3 mt-2 text-sm text-slate-600">初回は新規登録  2回目以降はログイン</p>
            <% if (loginError) { %>
              <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= loginError %></div>
            <% } %>
            <form action="/session" method="post" class="space-y-3">
              <input type="text" name="userId" value="<%= prefillUserId %>" placeholder="ユーザーID（半角英数字のみ）" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
              <div class="flex gap-2">
                <button type="submit" name="action" value="login" class="w-1/2 rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white">ログイン</button>
                <button type="submit" name="action" value="register" class="w-1/2 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700">新規登録</button>
              </div>
            </form>
          <% } else { %>
            <h2 class="text-xl font-bold">新しいタスク</h2>
            <form action="/tasks" method="post" class="mt-4 space-y-2.5">
              <input type="text" name="content" placeholder="タスク名" required class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
              <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">進捗</label>
                <input type="range" name="progress" min="0" max="100" step="10" value="0" class="w-full progress-slider" data-progress-display="new-progress-display">
                <div class="mt-1 text-xs text-slate-500">現在: <span id="new-progress-display">0</span>%</div>
              </div>
              <textarea name="details" rows="4" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm" placeholder="詳細"></textarea>
              <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">優先度</label>
                <select name="priority" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
                  <option value="high">優先度：高</option>
                  <option value="normal" selected>優先度：中</option>
                  <option value="low">優先度：低</option>
                </select>
              </div>
              <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">期限</label>
                <% 
                  const defaultDueDate = (() => {
                    const d = new Date();
                    d.setHours(23, 59, 59, 0);
                    const offset = d.getTimezoneOffset() * 60000;
                    const localDate = new Date(d.getTime() - offset);
                    return localDate.toISOString().slice(0, 19);
                  })();
                %>
                <input type="datetime-local" id="new-task-duedate" name="dueDate" value="<%= defaultDueDate %>" step="1" class="w-full rounded-lg border border-slate-300 px-2.5 py-2 text-sm">
                
                <div class="mt-1.5 flex flex-wrap gap-1.5">
                  <button type="button" onclick="setNewTaskDueDate(0)" class="rounded bg-slate-200 hover:bg-slate-300 px-2 py-1 text-[11px] font-medium text-slate-700 transition-colors">今日中</button>
                  <button type="button" onclick="setNewTaskDueDate(7)" class="rounded bg-slate-200 hover:bg-slate-300 px-2 py-1 text-[11px] font-medium text-slate-700 transition-colors">1週間後</button>
                  <button type="button" onclick="clearNewTaskDueDate()" class="rounded bg-red-50 hover:bg-red-100 px-2 py-1 text-[11px] font-medium text-red-600 border border-red-200 transition-colors">期限なし (クリア)</button>
                </div>
              </div>

              <button type="submit" class="w-full rounded-full bg-sky-600 px-3 py-2 text-sm font-semibold text-white">追加</button>
            </form>
          <% } %>
        </aside>
    </section>
  </div>

  <script>
    function setNewTaskDueDate(daysOffset) {
      const input = document.getElementById('new-task-duedate');
      const d = new Date();
      d.setDate(d.getDate() + daysOffset);
      d.setHours(23, 59, 59, 0);
      const offset = d.getTimezoneOffset() * 60000;
      const localIso = new Date(d.getTime() - offset).toISOString().slice(0, 19);
      input.value = localIso;
    }

    function clearNewTaskDueDate() {
      document.getElementById('new-task-duedate').value = '';
    }

    function updateRemainingTimes() {
      const now = Date.now();

      document.querySelectorAll('[data-remaining-target]').forEach((element) => {
        const dueDateValue = element.dataset.dueDate;
        if (!dueDateValue) {
          element.textContent = '';
          return;
        }

        const targetTime = new Date(dueDateValue).getTime();
        const remainingSeconds = Math.max(0, Math.floor((targetTime - now) / 1000));
        const isUrgent = remainingSeconds > 0 && remainingSeconds <= 21600;
        const article = element.closest('article');

        // 削除確認中（カードのクリック状態）でない場合のみ、期限間近のスタイルを適用
        if (article && !article.dataset.deleteConfirmed) { 
          // 期限間近のスタイル指定を「赤」から「黄色系(amber)」に変更
          article.classList.toggle('border-amber-500', isUrgent);
          article.classList.toggle('bg-amber-50', isUrgent);
          article.classList.toggle('ring-2', isUrgent);
          article.classList.toggle('ring-amber-300', isUrgent);

          // 以前の赤枠の残存を防ぐため明示的に削除クラスを指定
          if (!isUrgent) {
            article.classList.remove('border-amber-500', 'bg-amber-50', 'ring-2', 'ring-amber-300');
          }
        }

        element.textContent = formatRemainingText(remainingSeconds);
      });
    }

    function formatRemainingText(seconds) {
      if (seconds <= 0) return '期限切れ';
      const h = Math.floor(seconds / 3600);
      const m = Math.floor((seconds % 3600) / 60);
      return `${h}時間${m}分`;
    }

    updateRemainingTimes();
    setInterval(updateRemainingTimes, 1000);

    document.querySelectorAll('.progress-slider').forEach((slider) => {
      const target = document.getElementById(slider.dataset.progressDisplay);
      if (target) {
        target.textContent = slider.value;
      }
      slider.addEventListener('input', () => {
        const target = document.getElementById(slider.dataset.progressDisplay);
        if (target) {
          target.textContent = slider.value;
        }
      });
    });

    const allTaskCards = document.querySelectorAll('article[data-task-card]');

    function resetAllTaskCardStates() {
      allTaskCards.forEach((card) => {
        card.dataset.deleteConfirmed = '';
        card.classList.remove('border-red-700', 'ring-4', 'ring-red-400');
      });
    }

    allTaskCards.forEach((article) => {
      article.addEventListener('click', (event) => {
        if (event.target.closest('button, select, input, textarea, form')) {
          return;
        }

        const taskId = article.dataset.taskCard;
        
        if (article.dataset.deleteConfirmed === 'true') {
          const form = document.getElementById(`delete-form-${taskId}`);
          if (form) form.submit();
        } else {
          resetAllTaskCardStates();

          article.dataset.deleteConfirmed = 'true';
          // 期限間近の黄色クラスを一時的にリセットして削除の赤枠を優先
          article.classList.remove('border-amber-500', 'bg-amber-50', 'ring-2', 'ring-amber-300');
          article.classList.add('border-red-700', 'ring-4', 'ring-red-400');
          
          setTimeout(() => {
            if (article.dataset.deleteConfirmed === 'true') {
              article.dataset.deleteConfirmed = '';
              article.classList.remove('border-red-700', 'ring-4', 'ring-red-400');
              // タイマー周期を待たずに期限間近のスタイルを復元
              updateRemainingTimes();
            }
          }, 3000);
        }
      });
    });
  </script>
</body>
</html>