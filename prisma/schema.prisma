generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id   Int    @id @default(autoincrement())
  name String
  age Int?
}

model Task {
  id        Int      @id @default(autoincrement())
  content   String   // タスクの内容
  createdAt DateTime @default(now()) // 作成日時
}